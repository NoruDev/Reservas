# Este es un archivo de ejemplo para las variables de entorno.
# Crea un archivo llamado '.env' en la carpeta 'server' y copia estos valores.
# NO subas el archivo .env real a GitHub.

# Configuración del servidor
PORT=3000
NODE_ENV=development

# Configuración de la base de datos (PostgreSQL)
# Si usas Render, aquí colocarás la 'Internal Database URL' que te proporciona Render.
DATABASE_URL=postgres://usuario:contraseña@host:puerto/nombre_base_de_datos

# Llave secreta para JWT o sesiones
# Usa una cadena de texto larga y aleatoria
SECRET_KEY=tu_llave_secreta_muy_larga_y_segura

# Otras configuraciones (ejemplo de APIs externas)
# API_KEY_CLOUDINARY=tu_api_key_aqui
# EMAIL_USER=tu_email@empresa.com
# EMAIL_PASS=tu_contraseña_de_aplicacion





